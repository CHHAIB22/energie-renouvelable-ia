{
  "name": "energie-renouvelable-ia",
  "version": "1.0.0",
  "description": "Classificateur IA de Sources d'Energie Renouvelable",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start-react": "set BROWSER=none && react-scripts start",
    "build-react": "react-scripts build",
    "electron-dev": "concurrently \"npm run start-react\" \"wait-on http://localhost:3000 && electron .\"",
    "dev": "npm run electron-dev",
    "build": "npm run build-react && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.10.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.energie.ia",
    "productName": "Energie Renouvelable IA",
    "directories": { "output": "dist" },
    "files": ["build/**/*", "electron/**/*", "python/**/*"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version"]
  }
}
